---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-charcoal/5 bg-cream py-12">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div>
        <a href="/" class="font-display text-xl font-bold text-wine">
          Cuvée
        </a>
        <p class="mt-1 text-sm text-muted">
          Le CRM pensé pour les cavistes.
        </p>
      </div>
      <div class="flex gap-6 text-sm text-muted">
        <a href="#comment-ca-marche" class="transition hover:text-wine">Comment ça marche</a>
        <a href="#fonctionnalites" class="transition hover:text-wine">Fonctionnalités</a>
      </div>
    </div>
    <div class="mt-8 border-t border-charcoal/5 pt-8 text-center text-sm text-muted">
      &copy; {currentYear} Cuvée. Tous droits réservés.
    </div>
  </div>
</footer>
