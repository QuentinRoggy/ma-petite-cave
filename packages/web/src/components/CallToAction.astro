---
import { APP_URL } from "../config";
---

<section class="relative overflow-hidden bg-wine py-20 md:py-28">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute -top-1/2 -right-1/4 h-[600px] w-[600px] rounded-full bg-gold blur-3xl"></div>
    <div class="absolute -bottom-1/2 -left-1/4 h-[500px] w-[500px] rounded-full bg-wine-deep blur-3xl"></div>
  </div>

  <div class="relative mx-auto max-w-3xl px-6 text-center">
    <h2 class="animate-on-scroll font-display text-3xl font-bold text-white md:text-5xl">
      Prêt à transformer la relation avec vos clients ?
    </h2>
    <p class="animate-on-scroll delay-1 mx-auto mt-6 max-w-xl text-lg text-white/70">
      Rejoignez les cavistes qui utilisent Ma Petite Cave pour offrir une expérience personnalisée à chaque client.
    </p>
    <div class="animate-on-scroll delay-2 mt-10">
      <a
        href={APP_URL}
        class="inline-block rounded-full bg-white px-8 py-4 text-base font-bold text-wine shadow-lg transition hover:bg-cream hover:shadow-xl"
      >
        Créer mon compte gratuitement
      </a>
    </div>
  </div>
</section>
