---
const steps = [
  {
    number: "01",
    title: "Créez une box",
    description: "Sélectionnez les vins de votre catalogue et composez une box personnalisée pour chaque client.",
    icon: "package",
  },
  {
    number: "02",
    title: "Le client découvre",
    description: "Votre client reçoit sa box avec les fiches détaillées de chaque vin : arômes, accords, histoire du domaine.",
    icon: "wine",
  },
  {
    number: "03",
    title: "Il note et commente",
    description: "Après dégustation, le client note chaque vin et partage ses impressions directement depuis son espace.",
    icon: "star",
  },
  {
    number: "04",
    title: "Il en redemande",
    description: "Un coup de cœur ? En un clic, il vous signale qu'il veut le regoûter. Vous êtes notifié instantanément.",
    icon: "heart",
  },
];
---

<section id="comment-ca-marche" class="bg-cream py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span class="animate-on-scroll mb-4 inline-block text-sm font-semibold tracking-widest text-wine uppercase">
        Comment ça marche
      </span>
      <h2 class="animate-on-scroll delay-1 font-display text-3xl font-bold text-charcoal md:text-4xl">
        Quatre étapes pour <span class="text-wine">fidéliser</span> vos clients
      </h2>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-4">
      {steps.map((step, i) => (
        <div class={`animate-on-scroll delay-${i + 1} relative`}>
          {i < 3 && (
            <div class="absolute top-8 left-full hidden h-px w-full bg-gradient-to-r from-wine/30 to-transparent md:block" />
          )}
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-wine/10">
            {step.icon === "package" && (
              <svg class="h-7 w-7 text-wine" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
              </svg>
            )}
            {step.icon === "wine" && (
              <svg class="h-7 w-7 text-wine" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19 14.5M14.25 3.104c.251.023.501.05.75.082M19 14.5a2.25 2.25 0 01-2.25 2.25H7.25A2.25 2.25 0 015 14.5m14 0V20a2 2 0 01-2 2H7a2 2 0 01-2-2v-5.5" />
              </svg>
            )}
            {step.icon === "star" && (
              <svg class="h-7 w-7 text-wine" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
              </svg>
            )}
            {step.icon === "heart" && (
              <svg class="h-7 w-7 text-wine" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
              </svg>
            )}
          </div>
          <span class="mb-2 block font-display text-sm font-bold text-wine/50">
            {step.number}
          </span>
          <h3 class="mb-2 font-display text-xl font-bold text-charcoal">
            {step.title}
          </h3>
          <p class="leading-relaxed text-muted">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
