---
const features = [
  {
    title: "Catalogue de vins",
    description: "Centralisez toutes les infos de vos vins : cépage, arômes, accords mets, potentiel de garde, prix.",
    icon: "catalog",
  },
  {
    title: "Gestion des clients",
    description: "Suivez vos abonnés, leurs préférences et leur historique de commandes en un coup d'œil.",
    icon: "clients",
  },
  {
    title: "Box mensuelles",
    description: "Composez des box personnalisées en quelques clics et assignez-les à vos clients.",
    icon: "box",
  },
  {
    title: "Feedback en temps réel",
    description: "Consultez les notes et commentaires de vos clients dès qu'ils dégustent.",
    icon: "feedback",
  },
  {
    title: "Re-commandes",
    description: "Vos clients signalent leurs coups de cœur. Vous êtes alerté pour préparer la prochaine commande.",
    icon: "reorder",
  },
  {
    title: "Tableau de bord",
    description: "Vue d'ensemble de votre activité : box envoyées, feedbacks reçus, vins les plus populaires.",
    icon: "dashboard",
  },
];
---

<section id="fonctionnalites" class="bg-cream-dark py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <span class="animate-on-scroll mb-4 inline-block text-sm font-semibold tracking-widest text-wine uppercase">
        Fonctionnalités
      </span>
      <h2 class="animate-on-scroll delay-1 font-display text-3xl font-bold text-charcoal md:text-4xl">
        Tout ce qu'il faut pour <span class="text-wine">gérer votre cave</span>
      </h2>
      <p class="animate-on-scroll delay-2 mt-4 text-lg text-muted">
        Une plateforme complète, pensée pour votre quotidien de caviste.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature, i) => (
        <div class={`animate-on-scroll delay-${(i % 3) + 1} group rounded-2xl border border-charcoal/5 bg-white p-7 transition hover:border-wine/20 hover:shadow-lg hover:shadow-wine/5`}>
          <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-wine/10 text-wine transition group-hover:bg-wine group-hover:text-white">
            {feature.icon === "catalog" && (
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
            )}
            {feature.icon === "clients" && (
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
              </svg>
            )}
            {feature.icon === "box" && (
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
              </svg>
            )}
            {feature.icon === "feedback" && (
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
              </svg>
            )}
            {feature.icon === "reorder" && (
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M21.015 4.356v4.992" />
              </svg>
            )}
            {feature.icon === "dashboard" && (
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
              </svg>
            )}
          </div>
          <h3 class="mb-2 font-display text-lg font-bold text-charcoal">
            {feature.title}
          </h3>
          <p class="text-sm leading-relaxed text-muted">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
