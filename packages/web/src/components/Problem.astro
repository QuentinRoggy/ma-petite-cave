---
const problems = [
  {
    icon: "brain",
    title: "Le client oublie",
    description:
      "Vous expliquez les arômes, les accords, l'histoire du domaine… mais une fois rentré chez lui, votre client ne s'en souvient plus.",
  },
  {
    icon: "silence",
    title: "Aucun retour",
    description:
      "Impossible de savoir ce que vos clients ont pensé de vos sélections. Vous recommandez à l'aveugle, sans données.",
  },
  {
    icon: "repeat",
    title: "Pas de re-commande simple",
    description:
      "Un client a adoré un vin ? Il n'a aucun moyen simple de vous le dire ou de le redemander.",
  },
];
---

<section class="bg-charcoal py-20 md:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="animate-on-scroll font-display text-3xl font-bold text-white md:text-4xl">
        Vos clients adorent vos sélections…<br />
        <span class="text-gold">mais vous ne le savez jamais</span>
      </h2>
      <p class="animate-on-scroll delay-1 mt-4 text-lg text-white/60">
        Aujourd'hui, la relation caviste-client s'arrête à la porte de la boutique.
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3 md:gap-8">
      {problems.map((problem, i) => (
        <div class={`animate-on-scroll delay-${i + 2} group rounded-2xl border border-white/10 bg-white/5 p-8 transition hover:border-wine/30 hover:bg-wine/5`}>
          <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl bg-wine/10 text-wine transition group-hover:bg-wine group-hover:text-white">
            {problem.icon === "brain" && (
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" />
              </svg>
            )}
            {problem.icon === "silence" && (
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
              </svg>
            )}
            {problem.icon === "repeat" && (
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 00-3.7-3.7 48.678 48.678 0 00-7.324 0 4.006 4.006 0 00-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3l-3-3m-12 3c0 1.232.046 2.453.138 3.662a4.006 4.006 0 003.7 3.7 48.656 48.656 0 007.324 0 4.006 4.006 0 003.7-3.7c.017-.22.032-.441.046-.662M4.5 12l3 3m-3-3l-3 3" />
              </svg>
            )}
          </div>
          <h3 class="mb-3 font-display text-xl font-bold text-white">
            {problem.title}
          </h3>
          <p class="leading-relaxed text-white/60">
            {problem.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
