---
import { APP_URL } from "../config";
---

<section class="relative overflow-hidden bg-cream pt-32 pb-20 md:pt-40 md:pb-32">
  <div class="absolute inset-0 opacity-[0.03]" style={`background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23722F37' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");`}></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <span class="mb-6 inline-block rounded-full border border-wine/20 bg-wine/5 px-4 py-1.5 text-sm font-medium text-wine">
        La plateforme pour cavistes passionnés
      </span>

      <h1 class="font-display text-4xl leading-tight font-bold tracking-tight text-charcoal md:text-6xl md:leading-[1.1]">
        Transformez chaque box en une
        <span class="text-wine">expérience mémorable</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted md:text-xl">
        Le CRM pensé pour les cavistes. Créez vos box, partagez vos fiches vins,
        recueillez les retours de vos clients — et affinez vos recommandations.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={APP_URL}
          class="rounded-full bg-wine px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-wine/20 transition hover:bg-wine-dark hover:shadow-xl hover:shadow-wine/30"
        >
          Essayer gratuitement
        </a>
        <a
          href="#comment-ca-marche"
          class="group flex items-center gap-2 rounded-full px-6 py-3.5 text-base font-medium text-charcoal/70 transition hover:text-wine"
        >
          Voir comment ça marche
          <svg class="h-4 w-4 transition group-hover:translate-y-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>

    <div class="mx-auto mt-16 max-w-4xl md:mt-20">
      <div class="relative rounded-2xl border border-charcoal/5 bg-white p-2 shadow-2xl shadow-charcoal/5">
        <div class="rounded-xl bg-gradient-to-br from-charcoal to-charcoal-light p-8 md:p-12">
          <div class="grid grid-cols-3 gap-4 md:gap-6">
            <!-- Wine card mockup 1 -->
            <div class="rounded-lg bg-white/10 p-3 backdrop-blur-sm md:p-5">
              <div class="mb-3 aspect-[3/4] rounded-md bg-wine/30"></div>
              <div class="mb-2 h-3 w-3/4 rounded bg-white/20"></div>
              <div class="h-2 w-1/2 rounded bg-white/10"></div>
              <div class="mt-3 flex gap-1">
                {[1, 2, 3, 4, 5].map((i) => (
                  <svg class:list={["h-3 w-3 md:h-4 md:w-4", i <= 4 ? "text-gold" : "text-white/20"]} fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            <!-- Wine card mockup 2 -->
            <div class="rounded-lg bg-white/10 p-3 backdrop-blur-sm md:p-5">
              <div class="mb-3 aspect-[3/4] rounded-md bg-gold/20"></div>
              <div class="mb-2 h-3 w-2/3 rounded bg-white/20"></div>
              <div class="h-2 w-2/5 rounded bg-white/10"></div>
              <div class="mt-3 flex gap-1">
                {[1, 2, 3, 4, 5].map((i) => (
                  <svg class:list={["h-3 w-3 md:h-4 md:w-4", i <= 5 ? "text-gold" : "text-white/20"]} fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
            <!-- Wine card mockup 3 -->
            <div class="rounded-lg bg-white/10 p-3 backdrop-blur-sm md:p-5">
              <div class="mb-3 aspect-[3/4] rounded-md bg-wine-deep/30"></div>
              <div class="mb-2 h-3 w-4/5 rounded bg-white/20"></div>
              <div class="h-2 w-1/3 rounded bg-white/10"></div>
              <div class="mt-3 flex gap-1">
                {[1, 2, 3, 4, 5].map((i) => (
                  <svg class:list={["h-3 w-3 md:h-4 md:w-4", i <= 3 ? "text-gold" : "text-white/20"]} fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                  </svg>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
