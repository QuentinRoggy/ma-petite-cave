---
import { APP_URL } from "../config";
---

<section class="relative overflow-hidden bg-cream pt-32 pb-20 md:pt-40 md:pb-32">
  <div class="absolute inset-0 opacity-[0.03]" style={`background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23722F37' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");`}></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-3xl text-center">
      <span class="mb-6 inline-block rounded-full border border-wine/20 bg-wine/5 px-4 py-1.5 text-sm font-medium text-wine">
        La plateforme pour cavistes passionnés
      </span>

      <h1 class="font-display text-4xl leading-tight font-bold tracking-tight text-charcoal md:text-6xl md:leading-[1.1]">
        Transformez chaque box en une
        <span class="text-wine">expérience mémorable</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted md:text-xl">
        Le CRM pensé pour les cavistes. Créez vos box, partagez vos fiches vins,
        recueillez les retours de vos clients — et affinez vos recommandations.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={APP_URL}
          class="rounded-full bg-wine px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-wine/20 transition hover:bg-wine-dark hover:shadow-xl hover:shadow-wine/30"
        >
          Essayer gratuitement
        </a>
        <a
          href="#comment-ca-marche"
          class="group flex items-center gap-2 rounded-full px-6 py-3.5 text-base font-medium text-charcoal/70 transition hover:text-wine"
        >
          Voir comment ça marche
          <svg class="h-4 w-4 transition group-hover:translate-y-0.5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
        </a>
      </div>
    </div>

    <div class="mx-auto mt-16 max-w-5xl md:mt-20" role="img" aria-label="Aperçu de l'interface Ma Petite Cave montrant un tableau de bord caviste avec fiches vins et notes clients">
      <div class="relative rounded-2xl border border-charcoal/5 bg-white p-1.5 shadow-2xl shadow-charcoal/10 md:p-2">
        <!-- Browser chrome -->
        <div class="flex items-center gap-2 rounded-t-lg bg-charcoal/[0.03] px-4 py-2.5">
          <div class="flex gap-1.5">
            <div class="h-2.5 w-2.5 rounded-full bg-charcoal/10"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-charcoal/10"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-charcoal/10"></div>
          </div>
          <div class="ml-2 flex-1 rounded-md bg-white/80 px-3 py-1 text-[10px] text-charcoal/30 md:text-xs">
            app.ma-petite-cave.fr/dashboard
          </div>
        </div>

        <!-- App UI -->
        <div class="flex rounded-b-lg bg-cream-dark">
          <!-- Sidebar -->
          <div class="hidden w-48 shrink-0 border-r border-charcoal/5 bg-white p-4 md:block">
            <p class="font-display text-sm font-bold text-wine">Ma Petite Cave</p>
            <nav class="mt-5 space-y-1 text-xs" aria-hidden="true">
              <div class="flex items-center gap-2 rounded-lg bg-wine/5 px-3 py-2 font-medium text-wine">
                <svg class="h-3.5 w-3.5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" /></svg>
                Tableau de bord
              </div>
              <div class="flex items-center gap-2 rounded-lg px-3 py-2 text-charcoal/50">
                <svg class="h-3.5 w-3.5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
                Mes vins
              </div>
              <div class="flex items-center gap-2 rounded-lg px-3 py-2 text-charcoal/50">
                <svg class="h-3.5 w-3.5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" /></svg>
                Box
              </div>
              <div class="flex items-center gap-2 rounded-lg px-3 py-2 text-charcoal/50">
                <svg class="h-3.5 w-3.5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" /></svg>
                Clients
              </div>
            </nav>
          </div>

          <!-- Main content -->
          <div class="flex-1 p-4 md:p-6">
            <!-- Header -->
            <div class="mb-5 flex items-center justify-between">
              <div>
                <p class="text-xs font-medium text-charcoal/40">Bonjour, Jean</p>
                <p class="font-display text-sm font-bold text-charcoal md:text-base">Tableau de bord</p>
              </div>
              <div class="flex gap-2">
                <div class="rounded-lg bg-wine/10 px-2.5 py-1 text-[10px] font-semibold text-wine md:text-xs">+ Nouvelle box</div>
              </div>
            </div>

            <!-- Stats row -->
            <div class="mb-5 grid grid-cols-3 gap-2 md:gap-3">
              <div class="rounded-xl bg-white p-3 shadow-sm">
                <p class="text-[10px] text-charcoal/40 md:text-xs">Box ce mois</p>
                <p class="font-display text-lg font-bold text-charcoal md:text-xl">12</p>
              </div>
              <div class="rounded-xl bg-white p-3 shadow-sm">
                <p class="text-[10px] text-charcoal/40 md:text-xs">Note moyenne</p>
                <p class="font-display text-lg font-bold text-wine md:text-xl">4.6 <span class="text-xs text-gold">&#9733;</span></p>
              </div>
              <div class="rounded-xl bg-white p-3 shadow-sm">
                <p class="text-[10px] text-charcoal/40 md:text-xs">Re-commandes</p>
                <p class="font-display text-lg font-bold text-charcoal md:text-xl">8</p>
              </div>
            </div>

            <!-- Recent feedback -->
            <div class="rounded-xl bg-white p-4 shadow-sm">
              <p class="mb-3 text-xs font-semibold text-charcoal/60">Derniers retours clients</p>
              <div class="space-y-3">
                <!-- Feedback 1 -->
                <div class="flex items-start gap-3">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-wine/10 text-xs font-bold text-wine">MC</div>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center justify-between gap-2">
                      <p class="truncate text-xs font-semibold text-charcoal">Marie C. <span class="font-normal text-charcoal/40">sur</span> Château Margaux 2019</p>
                      <div class="flex shrink-0 gap-0.5">
                        {[1,2,3,4,5].map(() => (
                          <svg aria-hidden="true" class="h-2.5 w-2.5 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                        ))}
                      </div>
                    </div>
                    <p class="mt-0.5 text-[11px] leading-relaxed text-charcoal/50">"Exceptionnel, des arômes de fruits noirs incroyables !"</p>
                  </div>
                </div>
                <!-- Feedback 2 -->
                <div class="flex items-start gap-3">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gold/10 text-xs font-bold text-gold">PD</div>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center justify-between gap-2">
                      <p class="truncate text-xs font-semibold text-charcoal">Pierre D. <span class="font-normal text-charcoal/40">sur</span> Chablis 1er Cru 2021</p>
                      <div class="flex shrink-0 gap-0.5">
                        {[1,2,3,4].map(() => (
                          <svg aria-hidden="true" class="h-2.5 w-2.5 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                        ))}
                        <svg aria-hidden="true" class="h-2.5 w-2.5 text-charcoal/10" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                      </div>
                    </div>
                    <p class="mt-0.5 text-[11px] leading-relaxed text-charcoal/50">"Très belle minéralité, parfait avec le poisson."</p>
                    <div class="mt-1 inline-flex items-center gap-1 rounded-full bg-wine/5 px-2 py-0.5 text-[10px] font-medium text-wine">
                      <svg aria-hidden="true" class="h-2.5 w-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182M21.015 4.356v4.992" /></svg>
                      Souhaite re-commander
                    </div>
                  </div>
                </div>
                <!-- Feedback 3 -->
                <div class="flex items-start gap-3">
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-wine-deep/10 text-xs font-bold text-wine-deep">SL</div>
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center justify-between gap-2">
                      <p class="truncate text-xs font-semibold text-charcoal">Sophie L. <span class="font-normal text-charcoal/40">sur</span> Sancerre Rosé 2023</p>
                      <div class="flex shrink-0 gap-0.5">
                        {[1,2,3,4,5].map(() => (
                          <svg aria-hidden="true" class="h-2.5 w-2.5 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                        ))}
                      </div>
                    </div>
                    <p class="mt-0.5 text-[11px] leading-relaxed text-charcoal/50">"Frais et fruité, idéal pour l'apéritif d'été !"</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
